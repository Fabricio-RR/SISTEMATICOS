# ── Base de datos ──────────────────────────────────────────────────
# Este archivo es para correr el BACKEND EN EL HOST (Opción B, sin Docker):
# uvicorn / los scripts corren en tu máquina, así que el host es "localhost"
# (puerto 3306 publicado por el contenedor de MySQL).
# El usuario, la clave y el nombre de la base deben coincidir con
# MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE del .env de la raíz.
# (En Opción A —todo en Docker— NO se usa este archivo: el contenedor backend
#  lee el .env de la raíz, cuyo DATABASE_URL apunta a "db" en vez de "localhost".)
DATABASE_URL=mysql+pymysql://olimpiadas_user:tu_password_aqui@localhost:3306/olimpiadas_peru

# ── Seguridad / JWT ────────────────────────────────────────────────
# Generar uno fuerte:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-largo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie del refresh token. En producción (HTTPS) usar SECURE=true.
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_PATH=/api/auth

# ── CORS ───────────────────────────────────────────────────────────
# Orígenes permitidos del frontend (separados por coma).
ALLOWED_ORIGINS=http://localhost:3000

# ── Correo (SMTP) ──────────────────────────────────────────────────
# Con EMAIL_ENABLED=false (o sin SMTP_HOST) los correos se loguean en
# consola en vez de enviarse: útil para desarrollo sin credenciales.
#
# Para pruebas reales con Gmail común:
#   EMAIL_ENABLED=true
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tucorreo@gmail.com
#   SMTP_PASSWORD=  → "Contraseña de aplicación" de 16 caracteres
#                     (https://myaccount.google.com/apppasswords, requiere 2FA)
#   SMTP_FROM=Olimpiadas Perú <tucorreo@gmail.com>
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Olimpiadas Perú <no-reply@olimpiadas.pe>
SMTP_TLS=true
