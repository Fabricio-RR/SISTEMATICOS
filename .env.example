# ── Base de datos ──────────────────────────────────────────────────
# Este .env de la raíz lo usa DOCKER COMPOSE (Opción A). MYSQL_* crea el
# contenedor de MySQL; el contenedor "backend" también lee este archivo.
# IMPORTANTE: MYSQL_USER/MYSQL_PASSWORD/MYSQL_DATABASE deben coincidir
# EXACTAMENTE con el usuario/clave/base que uses en DATABASE_URL.
MYSQL_ROOT_PASSWORD=tu_password_root
MYSQL_DATABASE=olimpiadas_peru
MYSQL_USER=olimpiadas_user
MYSQL_PASSWORD=tu_password_aqui

# Host = "db": dentro de la red de Docker el backend llega a MySQL por el
# nombre del servicio. (Si corres el backend en el HOST sin Docker, usa el
# archivo backend/.env, que apunta a "localhost".)
DATABASE_URL=mysql+pymysql://olimpiadas_user:tu_password_aqui@db:3306/olimpiadas_peru

# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_una_clave_secreta_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_PATH=/api/auth

# CORS: lista separada por comas. En producción agregar el dominio real.
ALLOWED_ORIGINS=http://localhost:3000

# Credenciales del admin inicial
SEED_ADMIN_EMAIL=admin@olimpiadas.pe
SEED_ADMIN_PASSWORD=cambia_esto_antes_de_produccion

NEXT_PUBLIC_API_URL=http://localhost:8000
