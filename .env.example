DATABASE_URL=mysql+pymysql://olimpiadas_user:tu_password_aqui@db:3306/olimpiadas_peru

# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_una_clave_secreta_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_PATH=/api/auth

# CORS: lista separada por comas. En producción agregar el dominio real.
ALLOWED_ORIGINS=http://localhost:3000

# Credenciales del admin inicial
SEED_ADMIN_EMAIL=admin@olimpiadas.pe
